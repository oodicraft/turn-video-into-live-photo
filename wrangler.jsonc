{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "turn-video-into-live-photo",
  "compatibility_date": "2026-07-03",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "turn2live.oodicraft.com",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true
  }
}
